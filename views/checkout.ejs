<!DOCTYPE html>
<html>

<head>
    <title>Checkout - Lumitani</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/style.css">
</head>

<body>

<div class="container">

    <!-- 🔙 Tombol back -->
    <a href="/" class="back-btn">← Kembali</a>

    <!-- Logo -->
    <div style="text-align:center;">
        <img src="/logo.png" class="logo">
    </div>

    <h2>Checkout</h2>
    <p>Ringkasan pesanan kamu</p>

    <div class="checkout-grid">

        <!-- KIRI -->
        <div>
            <div class="card">
                <h3>Ringkasan Pesanan</h3>

                <div class="product">
                    <div class="product-icon">🥬</div>
                    <div class="product-info">
                        <p>Bayam Organik</p>
                        <small>Rp 10.000 x 1</small>
                        <div class="price">Rp 10.000</div>
                    </div>
                </div>

                <div class="product">
                    <div class="product-icon">🥦</div>
                    <div class="product-info">
                        <p>Kangkung Segar</p>
                        <small>Rp 10.000 x 1</small>
                        <div class="price">Rp 10.000</div>
                    </div>
                </div>

                <hr>
                <p><b>Total: Rp 20.000</b></p>
            </div>
        </div>

        <!-- KANAN -->
        <div>
            <form action="/order" method="POST">

                <div class="card">
                    <h3>Alamat Pengiriman</h3>

                    <input type="text" name="name" placeholder="Nama Penerima" required>
                    <input type="text" name="phone" placeholder="Nomor Telepon">

                    <textarea name="address" placeholder="Alamat Lengkap" required></textarea>

                    <div class="row">
                        <input type="text" name="city" placeholder="Kota">
                        <input type="text" name="postal" placeholder="Kode Pos">
                    </div>
                </div>

                <div class="card payment">
                    <h3>Metode Pembayaran</h3>

                    <div class="card payment">
    <h3>Metode Pembayaran</h3>

    <!-- BANK -->
    <p><b>Transfer Bank</b></p>

    <div class="bank-list">

    <label class="bank-item">
        <input type="radio" name="payment" value="bca" required>
        <div class="bank-content">
            <img src="/bca.png">
            <span>BCA</span>
        </div>
    </label>

    <label class="bank-item">
        <input type="radio" name="payment" value="mandiri">
        <div class="bank-content">
            <img src="/mandiri.png">
            <span>Mandiri</span>
        </div>
    </label>

    <label class="bank-item">
        <input type="radio" name="payment" value="bni">
        <div class="bank-content">
            <img src="/bni.png">
            <span>BNI</span>
        </div>
    </label>

</div>

    <!-- LAINNYA -->
    <p style="margin-top:15px;"><b>Lainnya</b></p>

    <p style="margin-top:15px;"><b>E-Wallet</b></p>

<div class="bank-list">

    <label class="bank-item">
        <input type="radio" name="payment" value="dana">
        <div class="bank-content">
            <img src="/dana.png">
            <span>DANA</span>
        </div>
    </label>

    <label class="bank-item">
        <input type="radio" name="payment" value="ovo">
        <div class="bank-content">
            <img src="/ovo.png">
            <span>OVO</span>
        </div>
    </label>

    <label class="bank-item">
        <input type="radio" name="payment" value="gopay">
        <div class="bank-content">
            <img src="/gopay.png">
            <span>GoPay</span>
        </div>
    </label>

</div>

    <label><input type="radio" name="payment" value="cod"> COD</label>

                    

                <button type="submit">Order Now</button>

            </form>
        </div>

    </div>

</div>

</body>
</html>