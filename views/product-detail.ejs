<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %> - Farm E-commerce</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/product-detail.css">
</head>
<body>
    <div class="app-container">
        <!-- Header -->
        <header class="header">
            <div class="header-back">
                <a href="/catalog" class="btn-back">← Kembali</a>
            </div>
        </header>

        <!-- Main Content -->
        <main class="main-content">
            <div class="product-detail">
                <div class="product-image-large">
                    <img src="<%= product.image %>" alt="<%= product.name %>">
                </div>
                
                <div class="product-details">
                    <h1><%= product.name %></h1>
                    <p class="category-badge"><%= product.category %></p>
                    
                    <div class="price-section">
                        <span class="price">Rp <%= product.price.toLocaleString('id-ID') %></span>
                        <span class="stock-status <%= product.stock > 0 ? 'available' : 'unavailable' %>">
                            <%= product.stock > 0 ? 'Tersedia' : 'Habis' %>
                        </span>
                    </div>

                    <p class="description"><%= product.description %></p>

                    <% if (product.keunggulan_produk && product.keunggulan_produk.length > 0) { %>
                    <div class="product-advantages">
                        <h3>Keunggulan Produk</h3>
                        <ul class="advantages-list">
                            <% product.keunggulan_produk.forEach(function(item) { %>
                                <li><span class="check-icon">✓</span> <%= item %></li>
                            <% }); %>
                        </ul>
                    </div>
                    <% } %>

                    <div class="product-info-cards">
                        <div class="info-card">
                            <span class="info-label">PETANI</span>
                            <span class="info-value"><%= product.farmer_name || 'N/A' %></span>
                        </div>
                        <div class="info-card">
                            <span class="info-label">STOK TERSEDIA</span>
                            <span class="info-value"><%= product.stock %> unit</span>
                        </div>
                        <% if (product.panen_terakhir) { %>
                        <div class="info-card">
                            <span class="info-label">PANEN TERAKHIR</span>
                            <span class="info-value"><%= Math.floor((Date.now() - new Date(product.panen_terakhir).getTime()) / (1000 * 60 * 60 * 24)) %> hari yang lalu</span>
                        </div>
                        <% } %>
                    </div>

                    <div class="stock-info">
                        <p>Stok tersedia: <strong><%= product.stock %></strong> unit</p>
                    </div>

                    <div class="quantity-selector">
                        <label for="quantity">Jumlah:</label>
                        <div class="quantity-control">
                            <button id="decreaseQty" type="button">-</button>
                            <input type="number" id="quantity" value="1" min="1" max="<%= product.stock %>">
                            <button id="increaseQty" type="button">+</button>
                        </div>
                    </div>

                    <% if (product.stock > 0) { %>
                        <button id="addToCartBtn" class="btn-add-to-cart" data-product-id="<%= product.id %>">
                            Tambah ke Keranjang
                        </button>
                    <% } else { %>
                        <button class="btn-add-to-cart" disabled>Stok Habis</button>
                    <% } %>
                </div>
            </div>
        </main>

        <!-- Bottom Navigation -->
        <nav class="bottom-nav">
            <a href="/" class="nav-item">
                <span class="nav-icon">🏠</span>
                <span class="nav-label">Home</span>
            </a>
            <a href="/catalog" class="nav-item">
                <span class="nav-icon">📦</span>
                <span class="nav-label">Katalog</span>
            </a>
            <a href="/cart" class="nav-item nav-center">
                <span class="nav-icon">🛒</span>
                <span class="nav-label">Keranjang</span>
            </a>
            <a href="/about" class="nav-item">
                <span class="nav-icon">ℹ️</span>
                <span class="nav-label">Tentang</span>
            </a>
            <a href="/profile" class="nav-item">
                <span class="nav-icon">👤</span>
                <span class="nav-label">Profil</span>
            </a>
        </nav>
    </div>

    <script src="/js/product-detail.js"></script>
</body>
</html>
