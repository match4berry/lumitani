<!DOCTYPE html>
<html>

<head>
    <title>Registrasi Admin - Lumitani</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body class="login-page">

    <div class="login-card">

        <a href="/" class="back-home">← Kembali ke Beranda</a>

        <img src="/logo.png" class="login-logo">

        <h2>Registrasi Admin</h2>

        <p class="login-subtitle">
            Buat akun admin untuk mengelola produk Lumitani
        </p>

        <form action="/register" method="POST">

            <input type="text" name="name" placeholder="Nama Admin" required>

            <input type="email" name="email" placeholder="Email" required>

            <input type="password" name="password" placeholder="Password" required>

            <button type="submit" class="login-button">
                Registrasi
            </button>

        </form>

        <p style="margin-top:15px;">
            Sudah punya akun?
            <a href="/login">Login</a>
        </p>

    </div>

</body>

</html>