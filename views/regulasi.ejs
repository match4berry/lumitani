<!DOCTYPE html>
<html>

<head>
    <title>Regulasi - Lumitani</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <!-- NAVBAR (biar konsisten) -->
    <nav class="navbar">

        <div class="logo">
            <img src="/logo.png" alt="LumiTani Logo">
        </div>

        <div class="menu">
            <a href="/">Home</a>
            <a href="/catalog">Produk</a>
            <a href="#">Harga</a>
            <a href="#">Tentang</a>
        </div>

        <div class="nav-right">
            <a href="/login" class="btn-login">Login</a>
        </div>

    </nav>

    <!-- HERO REGULASI -->
    <section class="reg-hero">
        <h1>📜 Regulasi Perdagangan</h1>
        <p>
            Lumitani mengacu pada PP No. 29 Tahun 2021 untuk memastikan
            transparansi harga, distribusi yang adil, dan perlindungan konsumen.
        </p>
    </section>

    <!-- CARD UTAMA -->
    <section class="reg-card">
        <h2>PP No. 29 Tahun 2021</h2>
        <p>
            Peraturan ini mengatur penyelenggaraan perdagangan di Indonesia,
            termasuk distribusi barang, kewajiban pelaku usaha, dan sistem perdagangan elektronik.
        </p>
    </section>

    <!-- FITUR REGULASI -->
    <section class="reg-features">

        <div class="card">
            <h3>Distribusi Terstruktur</h3>
            <p>Barang harus didistribusikan secara efisien dan jelas.</p>
        </div>

        <div class="card">
            <h3>Transparansi Harga</h3>
            <p>Harga harus terbuka dan dapat diakses oleh konsumen.</p>
        </div>

        <div class="card">
            <h3>Legalitas Usaha</h3>
            <p>Pelaku usaha wajib memiliki izin resmi (NIB).</p>
        </div>

    </section>

    <!-- PDF VIEWER -->
    <section class="reg-pdf">
        <h2>Dokumen Resmi</h2>
        <iframe src="/docs/pp29.pdf"></iframe>
    </section>

    <!-- BACK BUTTON -->
    <div class="reg-back">
        <a href="/" class="btn-primary">⬅ Kembali ke Home</a>
    </div>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 Lumitani Platform</p>
    </footer>

</body>

</html>