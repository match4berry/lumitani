<% layout = 'layout' %>

<header class="page-header">
    <div class="header-logo">
        <img src="/logo.png" alt="LumiTani" class="logo-image">
    </div>
</header>

<div class="address-content">
    <!-- Add New Address Button -->
    <div class="address-actions-top">
        <button class="btn-add-address" onclick="openAddressForm('add')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Tambah Alamat Baru
        </button>
    </div>

    <!-- Address Cards Container -->
    <div class="address-cards" id="addressCardsContainer">
        <div style="text-align: center; padding: 2rem; color: #999;">
            <p>Loading alamat...</p>
        </div>
    </div>

    <!-- Tips Section -->
    <div class="tips-section">
        <div class="tips-icon">
            <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3" fill="white"/>
            </svg>
        </div>
        <div class="tips-content">
            <h4 class="tips-title">Tips Alamat</h4>
            <p class="tips-text">Pastikan alamat lengkap dan benar untuk pengiriman yang lancar</p>
        </div>
    </div>
</div>

<!-- Address Form Modal -->
<div class="modal" id="addressModal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Alamat Pengiriman</h2>
            <button class="modal-close" onclick="closeAddressForm()">×</button>
        </div>
        <form id="addressForm" onsubmit="saveAddress(event)">
            <div class="form-group">
                <label for="addressLabel">Label Alamat (Rumah, Kantor, dll)</label>
                <input type="text" id="addressLabel" name="label" placeholder="contoh: Rumah, Kantor">
            </div>

            <div class="form-group">
                <label for="addressName">Nama Penerima *</label>
                <input type="text" id="addressName" name="name" required placeholder="Nama lengkap penerima">
            </div>

            <div class="form-group">
                <label for="addressPhone">Nomor Telepon *</label>
                <input type="tel" id="addressPhone" name="phone" required placeholder="08123456789">
            </div>

            <div class="form-group">
                <label for="addressFull">Alamat Lengkap *</label>
                <textarea id="addressFull" name="address" required placeholder="Jl. Raya No. 123, RT 01 RW 01"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="addressCity">Kota/Kabupaten</label>
                    <input type="text" id="addressCity" name="city" placeholder="contoh: Jakarta Selatan">
                </div>
                <div class="form-group">
                    <label for="addressPostal">Kode Pos</label>
                    <input type="text" id="addressPostal" name="postal_code" placeholder="12345">
                </div>
            </div>

            <div class="form-group form-checkbox">
                <input type="checkbox" id="addressPrimary" name="is_primary">
                <label for="addressPrimary">Jadikan alamat utama</label>
            </div>

            <div class="form-actions">
                <button type="button" class="btn-cancel" onclick="closeAddressForm()">Batal</button>
                <button type="submit" class="btn-save">Simpan</button>
                <button type="button" class="btn-delete" id="deleteBtn" style="display: none;" onclick="deleteAddress()">Hapus</button>
            </div>
        </form>
    </div>
</div>

<style>
.address-actions-top {
    margin-bottom: 2rem;
    display: flex;
    justify-content: flex-end;
}

.btn-add-address {
    background: #22c55e;
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
}

.btn-add-address:hover {
    background: #16a34a;
    transform: translateY(-2px);
}

.btn-add-address svg {
    width: 20px;
    height: 20px;
}

/* Modal Styles */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}

.modal.active {
    display: flex;
}

.modal-content {
    background: white;
    border-radius: 12px;
    max-width: 500px;
    width: 90%;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid #e5e7eb;
}

.modal-header h2 {
    margin: 0;
    font-size: 1.25rem;
}

.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #9ca3af;
}

.modal-close:hover {
    color: #6b7280;
}

.form-group {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
}

.form-group:last-of-type {
    border-bottom: none;
}

.form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    color: #374151;
}

.form-group input,
.form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 1rem;
    font-family: inherit;
}

.form-group textarea {
    resize: vertical;
    min-height: 100px;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #f3f4f6;
}

.form-row .form-group {
    padding: 0;
    border: none;
}

.form-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem !important;
}

.form-checkbox input {
    width: auto;
}

.form-checkbox label {
    margin: 0;
    font-weight: 400;
}

.form-actions {
    display: flex;
    gap: 1rem;
    padding: 1.5rem;
    justify-content: flex-end;
}

.btn-cancel,
.btn-save,
.btn-delete {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-cancel {
    background: #e5e7eb;
    color: #374151;
}

.btn-cancel:hover {
    background: #d1d5db;
}

.btn-save {
    background: #22c55e;
    color: white;
}

.btn-save:hover {
    background: #16a34a;
}

.btn-delete {
    background: #ef4444;
    color: white;
}

.btn-delete:hover {
    background: #dc2626;
}
</style>

<script>
// API configuration
const API_BASE_URL = 'http://localhost:8000/api';
let currentAddressId = null;
let authToken = null;

// Initialize page
document.addEventListener('DOMContentLoaded', function() {
    // Get auth token from server session
    fetch('/api/users/me')
        .then(response => {
            if (!response.ok) throw new Error('Not authenticated');
            return response.json();
        })
        .then(data => {
            authToken = data.token;
            console.log('[ADDRESS] User authenticated, token obtained');
            loadAddresses();
        })
        .catch(error => {
            console.error('[ADDRESS] Authentication error:', error);
            alert('Silakan login terlebih dahulu');
            window.location.href = '/login';
        });
});

// Load addresses from API
async function loadAddresses() {
    try {
        console.log('[ADDRESS] Loading addresses from API');
        const response = await fetch(`${API_BASE_URL}/addresses`, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${authToken}`
            }
        });

        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }

        const data = await response.json();
        console.log('[ADDRESS] Addresses loaded:', data);
        renderAddresses(data.addresses || []);
    } catch (error) {
        console.error('[ADDRESS] Error loading addresses:', error);
        document.getElementById('addressCardsContainer').innerHTML = `
            <div style="text-align: center; padding: 2rem; color: #ef4444;">
                <p>Error memuat alamat: ${error.message}</p>
            </div>
        `;
    }
}

// Render addresses to page
function renderAddresses(addresses) {
    const container = document.getElementById('addressCardsContainer');
    
    if (addresses.length === 0) {
        container.innerHTML = `
            <div style="text-align: center; padding: 2rem; color: #9ca3af;">
                <p>Belum ada alamat tersimpan</p>
            </div>
        `;
        return;
    }

    container.innerHTML = addresses.map(addr => `
        <div class="address-card ${addr.is_primary ? 'primary' : ''}">
            <div class="address-header">
                <div class="address-icon">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20 10c0 7-8 12-8 12s-8-5-8-12a8 8 0 1 1 16 0z"/>
                        <circle cx="12" cy="10" r="3" fill="white"/>
                    </svg>
                </div>
                <div class="address-title">
                    <h3 class="address-name">${addr.label || 'Alamat'}</h3>
                    <span class="address-label">${addr.is_primary ? 'Alamat Utama' : ''}</span>
                </div>
                <div class="address-actions">
                    <button class="action-btn edit" onclick="openAddressForm('edit', ${addr.id})">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="address-details">
                <p class="detail-row"><strong>${addr.name}</strong></p>
                <p class="detail-row">${addr.phone}</p>
                <p class="detail-row">${addr.address}</p>
                ${addr.city ? `<p class="detail-row">${addr.city}${addr.postal_code ? `, ${addr.postal_code}` : ''}</p>` : ''}
            </div>
            
            ${!addr.is_primary ? `
                <div class="address-footer">
                    <button class="btn-set-primary" onclick="setPrimary(${addr.id})">Jadikan Utama</button>
                </div>
            ` : ''}
        </div>
    `).join('');
}

// Open address form (add or edit)
async function openAddressForm(mode, addressId = null) {
    currentAddressId = addressId;
    const modal = document.getElementById('addressModal');
    const form = document.getElementById('addressForm');
    const deleteBtn = document.getElementById('deleteBtn');
    
    // Reset form
    form.reset();
    
    if (mode === 'add') {
        document.querySelector('.modal-header h2').textContent = 'Tambah Alamat Baru';
        deleteBtn.style.display = 'none';
    } else if (mode === 'edit' && addressId) {
        document.querySelector('.modal-header h2').textContent = 'Edit Alamat';
        deleteBtn.style.display = 'block';
        
        // Load address data
        try {
            const response = await fetch(`${API_BASE_URL}/addresses/${addressId}`, {
                method: 'GET',
                headers: {
                    'Authorization': `Bearer ${authToken}`
                }
            });
            
            if (!response.ok) throw new Error('Failed to load address');
            
            const data = await response.json();
            const addr = data.address;
            
            document.getElementById('addressLabel').value = addr.label || '';
            document.getElementById('addressName').value = addr.name;
            document.getElementById('addressPhone').value = addr.phone;
            document.getElementById('addressFull').value = addr.address;
            document.getElementById('addressCity').value = addr.city || '';
            document.getElementById('addressPostal').value = addr.postal_code || '';
            document.getElementById('addressPrimary').checked = addr.is_primary;
        } catch (error) {
            console.error('Error loading address:', error);
            alert('Gagal memuat data alamat');
            return;
        }
    }
    
    modal.classList.add('active');
}

// Close address form
function closeAddressForm() {
    const modal = document.getElementById('addressModal');
    modal.classList.remove('active');
    currentAddressId = null;
}

// Save address (create or update)
async function saveAddress(event) {
    event.preventDefault();
    
    const formData = {
        label: document.getElementById('addressLabel').value || null,
        name: document.getElementById('addressName').value,
        phone: document.getElementById('addressPhone').value,
        address: document.getElementById('addressFull').value,
        city: document.getElementById('addressCity').value || null,
        postal_code: document.getElementById('addressPostal').value || null,
        is_primary: document.getElementById('addressPrimary').checked
    };

    try {
        const method = currentAddressId ? 'PUT' : 'POST';
        const url = currentAddressId 
            ? `${API_BASE_URL}/addresses/${currentAddressId}`
            : `${API_BASE_URL}/addresses`;

        const response = await fetch(url, {
            method: method,
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${authToken}`
            },
            body: JSON.stringify(formData)
        });

        if (!response.ok) throw new Error('Failed to save address');

        console.log('[ADDRESS] Address saved successfully');
        closeAddressForm();
        loadAddresses();
    } catch (error) {
        console.error('[ADDRESS] Error saving address:', error);
        alert('Gagal menyimpan alamat: ' + error.message);
    }
}

// Delete address
async function deleteAddress() {
    if (!currentAddressId) return;
    
    if (!confirm('Yakin ingin menghapus alamat ini?')) return;

    try {
        const response = await fetch(`${API_BASE_URL}/addresses/${currentAddressId}`, {
            method: 'DELETE',
            headers: {
                'Authorization': `Bearer ${authToken}`
            }
        });

        if (!response.ok) throw new Error('Failed to delete address');

        console.log('[ADDRESS] Address deleted successfully');
        closeAddressForm();
        loadAddresses();
    } catch (error) {
        console.error('[ADDRESS] Error deleting address:', error);
        alert('Gagal menghapus alamat: ' + error.message);
    }
}

// Set address as primary
async function setPrimary(addressId) {
    try {
        const response = await fetch(`${API_BASE_URL}/addresses/${addressId}/set-primary`, {
            method: 'PUT',
            headers: {
                'Authorization': `Bearer ${authToken}`
            }
        });

        if (!response.ok) throw new Error('Failed to set primary address');

        console.log('[ADDRESS] Address set as primary');
        loadAddresses();
    } catch (error) {
        console.error('[ADDRESS] Error setting primary address:', error);
        alert('Gagal mengatur alamat utama: ' + error.message);
    }
}
</script>
