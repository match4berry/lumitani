<% layout = 'layout' %>

<link rel="stylesheet" href="/css/pesanan-saya.css">

<style>
    .loading {
        text-align: center;
        padding: 2rem;
        color: #999;
    }
    
    .success-banner {
        background: #d1fae5;
        border: 2px solid #10b981;
        color: #047857;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        display: none;
    }
    
    .success-banner.show {
        display: block;
        animation: slideDown 0.3s ease-out;
    }
    
    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<header class="page-header">
    <div class="header-logo">
        <img src="/logo.png" alt="LumiTani" class="logo-image">
    </div>
</header>

<div class="orders-container">
    <!-- Success Banner -->
    <div class="success-banner" id="successBanner">
        <strong>✓ Pesanan Berhasil Dibuat!</strong> Pesanan Anda telah ditambahkan ke daftar pesanan.
    </div>

    <!-- Sidebar Filter Section -->
    <aside class="filter-sidebar">
        <h2 class="filter-title">Urutkan</h2>
        <div class="filter-buttons">
            <button class="filter-btn active" data-status="all">Semua</button>
            <button class="filter-btn" data-status="Menunggu Diproses">Menunggu Proses</button>
            <button class="filter-btn" data-status="Diproses">Diproses</button>
            <button class="filter-btn" data-status="Pengiriman">Pengiriman</button>
            <button class="filter-btn" data-status="Selesai">Selesai</button>
        </div>
    </aside>

    <!-- Main Content Section -->
    <main class="orders-main">
        <!-- Tabs Section -->
        <div class="tabs-section">
            <button class="tab-button active" data-tab="newest">Terbaru</button>
            <button class="tab-button" data-tab="oldest">Terlama</button>
        </div>

        <!-- Orders List -->
        <div class="orders-list" id="ordersList">
            <div class="loading">
                <p>Memuat pesanan...</p>
            </div>
        </div>

        <!-- Pagination -->
        <div class="pagination" id="paginationContainer" style="display: none;">
            <button class="pagination-btn prev">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            
            <div id="paginationBtns"></div>
            
            <button class="pagination-btn next">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>
        </div>
    </main>
</div>

<script>
    const PAGE_SIZE = 5;
    let authToken = null;
    let allOrders = [];
    let filteredOrders = [];
    let currentPage = 1;
    let currentStatus = 'all';
    let currentSort = 'newest';
    
    // Get auth token and user ID from session
    async function loadAuthInfo() {
        try {
            const response = await fetch('/api/users/me');
            if (!response.ok) {
                console.log('[ORDER-HISTORY] Failed to get user info');
                return null;
            }
            const data = await response.json();
            authToken = data.token;
            const userId = data.user?.id;
            console.log('[ORDER-HISTORY] Auth info obtained - user_id:', userId, 'token:', !!authToken);
            return { 
                user_id: userId,
                token: authToken,
                user: data.user
            };
        } catch (error) {
            console.error('[ORDER-HISTORY] Error getting auth info:', error);
            return null;
        }
    }
    
    // Load orders from backend API only (filtered by user_id)
    async function loadBackendOrders(userId) {
        try {
            if (!authToken) {
                console.log('[ORDER-HISTORY] No token, cannot load orders');
                return [];
            }
            
            // Fetch only authenticated user's orders
            const apiUrl = userId 
                ? `http://localhost:8000/api/orders?user_id=${userId}`
                : `http://localhost:8000/api/orders`;
            
            console.log('[ORDER-HISTORY] Loading orders from backend API:', apiUrl);
            const response = await fetch(apiUrl, {
                headers: {
                    'Authorization': `Bearer ${authToken}`
                }
            });
            
            if (!response.ok) {
                console.warn('[ORDER-HISTORY] Backend API returned status', response.status);
                return [];
            }
            const data = await response.json();
            console.log('[ORDER-HISTORY] Loaded', Array.isArray(data) ? data.length : 0, 'orders from backend');
            return Array.isArray(data) ? data : [];
        } catch (error) {
            console.error('[ORDER-HISTORY] Error loading backend orders:', error);
            return [];
        }
    }
    
    // Transform orders to unified format
    function transformOrders(orders) {
        return orders.map(order => {
            // Backend format from PostgreSQL 
            if (order.order_code) {
                return {
                    id: order.order_code,
                    databaseId: order.id,
                    name: order.customer_name,
                    phone: order.no_hp,
                    address: order.pengiriman,
                    city: order.city || '',
                    postal: order.postal || '',
                    total: parseInt(order.total_price || 0),
                    status: order.status === 'menunggu_proses' ? 'Menunggu Diproses' : 
                           order.status === 'diproses' ? 'Diproses' :
                           order.status === 'dikirim' ? 'Pengiriman' :
                           order.status === 'selesai' ? 'Selesai' : order.status,
                    items: (order.items || []).map(item => ({
                        id: item.id,
                        product_id: item.product_id,
                        name: item.product_name || item.name || 'Unknown Product',
                        quantity: parseInt(item.quantity || 0),
                        price: parseInt(item.unit_price || 0),
                        subtotal: parseInt(item.subtotal || 0)
                    })),
                    createdAt: order.order_date || order.created_at || new Date(),
                    userId: order.user_id,
                    source: 'backend'
                };
            } else {
                // Fallback: if someone passes non-backend format, skip it
                console.warn('[ORDER-HISTORY] Unknown order format:', order);
                return null;
            }
        }).filter(order => order !== null);
    }
    
    // Load and parse orders
    async function loadOrders() {
        try {
            console.log('[ORDER-HISTORY] Starting to load orders...');
            
            // Get user info including user_id
            const userInfo = await loadAuthInfo();
            if (!userInfo) {
                console.warn('[ORDER-HISTORY] Could not get user info, redirecting to login');
                // Don't redirect - show message instead
                const ordersList = document.getElementById('ordersList');
                if (ordersList) {
                    ordersList.innerHTML = `
                        <div class="empty-state" style="text-align: center; padding: 2rem;">
                            <p style="color: #dc2626; margin-bottom: 1rem;">Silakan login untuk melihat pesanan Anda</p>
                            <a href="/login" class="cta-button" style="display: inline-block; background: #10b981; color: white; padding: 0.5rem 1.5rem; border-radius: 6px; text-decoration: none;">Login</a>
                        </div>
                    `;
                }
                return;
            }
            
            const userId = userInfo.user_id;
            console.log('[ORDER-HISTORY] User ID:', userId, 'Token available:', !!authToken);
            
            if (!userId) {
                console.warn('[ORDER-HISTORY] No user_id in session');
                const ordersList = document.getElementById('ordersList');
                if (ordersList) {
                    ordersList.innerHTML = '<div class="empty-state"><p style="color: #dc2626;">Session expired, silakan login kembali</p></div>';
                }
                return;
            }
            
            // Load ONLY backend orders for this user
            console.log('[ORDER-HISTORY] Fetching orders for user_id:', userId);
            const backendOrders = await loadBackendOrders(userId);
            console.log('[ORDER-HISTORY] Backend returned', backendOrders.length, 'orders');
            
            if (backendOrders.length === 0) {
                console.log('[ORDER-HISTORY] No orders found, checking if API is accessible...');
                // Try to fetch all orders to see if API is working
                try {
                    const testResponse = await fetch('http://localhost:8000/api/orders', {
                        headers: {
                            'Authorization': `Bearer ${authToken}`
                        }
                    });
                    const allOrders = await testResponse.json();
                    console.log('[ORDER-HISTORY] Total orders in DB:', allOrders.length);
                    console.log('[ORDER-HISTORY] Sample order user_id values:', allOrders.slice(0, 3).map(o => o.user_id));
                } catch (e) {
                    console.error('[ORDER-HISTORY] Could not test API:', e);
                }
            }
            
            // Transform orders to unified format
            allOrders = transformOrders(backendOrders);
            console.log('[ORDER-HISTORY] Transformed to', allOrders.length, 'orders');
            
            if (allOrders.length > 0) {
                console.log('[ORDER-HISTORY] Sample transformed order:', allOrders[0]);
            }
            
            // Show success banner if new order was just created
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('new') === 'true') {
                console.log('[ORDER-HISTORY] New order flag detected, showing success banner');
                const banner = document.getElementById('successBanner');
                if (banner) {
                    banner.classList.add('show');
                    // Remove the ?new=true parameter
                    window.history.replaceState({}, document.title, '/order-history');
                    setTimeout(() => {
                        banner.classList.remove('show');
                    }, 5000);
                }
            }
            
            filterAndPaginate();
        } catch (error) {
            console.error('[ORDER-HISTORY] Error loading orders:', error);
            const ordersList = document.getElementById('ordersList');
            if (ordersList) {
                ordersList.innerHTML = `
                    <div class="empty-state">
                        <p style="color: #dc2626; margin-bottom: 1rem;">Gagal memuat pesanan</p>
                        <p style="font-size: 0.9rem; color: #999;">Error: ${error.message}</p>
                        <a href="javascript:location.reload()" style="display: inline-block; background: #10b981; color: white; padding: 0.5rem 1.5rem; border-radius: 6px; text-decoration: none; margin-top: 1rem;">Coba Lagi</a>
                    </div>
                `;
            }
        }
    }
    
    // Filter and paginate orders
    function filterAndPaginate() {
        // Filter by status
        filteredOrders = allOrders.filter(order => {
            if (currentStatus === 'all') return true;
            return order.status === currentStatus;
        });
        
        // Sort
        if (currentSort === 'oldest') {
            filteredOrders.sort((a, b) => new Date(a.createdAt) - new Date(b.createdAt));
        } else {
            filteredOrders.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
        }
        
        currentPage = 1;
        renderOrders();
        setupPagination();
    }
    
    // Render orders
    function renderOrders() {
        const startIdx = (currentPage - 1) * PAGE_SIZE;
        const endIdx = startIdx + PAGE_SIZE;
        const pageOrders = filteredOrders.slice(startIdx, endIdx);
        
        if (pageOrders.length === 0) {
            document.getElementById('ordersList').innerHTML = `
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                    <h2>Belum ada pesanan</h2>
                    <p>Mulai berbelanja sekarang untuk membuat pesanan Anda</p>
                    <a href="/catalog" class="cta-button">Belanja Sekarang</a>
                </div>
            `;
            return;
        }
        
        const html = pageOrders.map(order => `
            <div class="order-card">
                <div class="order-header">
                    <div class="order-info">
                        <h3 class="seller-name">${order.address || 'Pengiriman'}</h3>
                        <p class="order-meta">
                            ${order.id} - ${new Date(order.createdAt).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })} : ${new Date(order.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' })}
                        </p>
                    </div>
                    <span class="status-badge ${order.status.toLowerCase().replace(/\s+/g, '-')}">
                        ${order.status}
                    </span>
                </div>

                <div class="order-items">
                    ${order.items && order.items.length > 0 ? order.items.map(item => {
                        const itemSubtotal = item.subtotal || (item.price * item.quantity);
                        return `
                        <div class="order-item">
                            <div class="item-image">
                                <img src="https://via.placeholder.com/80?text=${encodeURIComponent(item.name.substring(0, 10))}" alt="${item.name}">
                            </div>
                            <div class="item-details">
                                <h4 class="item-name">${item.name}</h4>
                                <p class="item-price">Rp ${(item.price || 0).toLocaleString('id-ID')} / pcs</p>
                            </div>
                            <div class="item-qty">
                                <span class="qty-label">Kuantitas</span>
                                <span class="qty-value">${item.quantity || 0}</span>
                            </div>
                            <div class="item-total">
                                <span class="total-label">Total</span>
                                <span class="total-value">Rp ${itemSubtotal.toLocaleString('id-ID')}</span>
                            </div>
                        </div>
                    `}).join('') : '<p style="padding: 1rem; color: #999;">Tidak ada item</p>'}
                </div>

                <div class="order-footer">
                    <div class="order-total">
                        <span class="total-label">Rp ${(order.total || 0).toLocaleString('id-ID')}</span>
                        <span class="items-count">sub total ${order.items ? order.items.length : 0} item</span>
                    </div>
                    <button class="complete-button">Lihat Detail</button>
                </div>
            </div>
        `).join('');
        
        document.getElementById('ordersList').innerHTML = html;
    }
    
    // Setup pagination
    function setupPagination() {
        const totalPages = Math.ceil(filteredOrders.length / PAGE_SIZE);
        const container = document.getElementById('paginationContainer');
        
        if (totalPages <= 1) {
            container.style.display = 'none';
            return;
        }
        
        container.style.display = 'flex';
        
        const btnsContainer = document.getElementById('paginationBtns');
        let btnsHtml = '';
        
        for (let i = 1; i <= totalPages; i++) {
            btnsHtml += `<button class="pagination-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
        }
        
        btnsContainer.innerHTML = btnsHtml;
        
        // Attach event listeners
        document.querySelectorAll('#paginationBtns .pagination-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                currentPage = parseInt(btn.dataset.page);
                renderOrders();
                setupPagination();
            });
        });
        
        // Previous/Next buttons
        document.querySelector('.pagination-btn.prev').onclick = () => {
            if (currentPage > 1) {
                currentPage--;
                renderOrders();
                setupPagination();
            }
        };
        
        document.querySelector('.pagination-btn.next').onclick = () => {
            if (currentPage < totalPages) {
                currentPage++;
                renderOrders();
                setupPagination();
            }
        };
    }
    
    // Event listeners
    document.addEventListener('DOMContentLoaded', () => {
        // Filter buttons
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentStatus = btn.dataset.status;
                filterAndPaginate();
            });
        });
        
        // Tab buttons
        document.querySelectorAll('.tab-button').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentSort = btn.dataset.tab;
                filterAndPaginate();
            });
        });
        
        // Load orders
        loadOrders();
        
        // Refresh every 10 seconds
        setInterval(loadOrders, 10000);
    });
</script>

