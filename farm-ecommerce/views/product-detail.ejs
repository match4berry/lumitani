<% layout = 'layout' %>

<div class="product-detail-page">
    <!-- Header -->
    <header class="page-header">
        <div class="header-logo">
            <img src="/logo.png" alt="LumiTani" class="logo-image">
        </div>
    </header>

    <!-- Main Content -->
    <div class="detail-container">
        <!-- Left: Product Images -->
        <div class="product-images-section">
            <div class="product-image-main">
                <img id="mainImage" src="<%= product.image || 'https://via.placeholder.com/500' %>" alt="<%= product.name %>">
            </div>
            <div class="product-thumbnails">
                <% for (let i = 0; i < 4; i++) { %>
                    <div class="thumbnail <%= i === 0 ? 'active' : '' %>" onclick="changeImage(this)">
                        <img src="<%= product.image || 'https://via.placeholder.com/100' %>" alt="Thumbnail <%= i + 1 %>">
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Right: Product Details -->
        <div class="product-info-section">
            <!-- Title with Badge -->
            <div class="product-header">
                <h1 class="product-title">
                    <%= product.name || 'Produk Organik' %>
                    <span class="premium-badge">Premium</span>
                </h1>
            </div>

            <!-- Description -->
            <p class="product-description">
                <%= product.description || 'Produk organik berkualitas dari petani lokal dengan harga terjangkau dan transparansi penuh.' %>
            </p>

            <!-- Product Advantages -->
            <div class="advantages-section">
                <h3 class="section-title">Keunggulan Produk</h3>
                <div class="advantages-list">
                    <div class="advantage-item">
                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>100% organik tanpa pestisida kimia</span>
                    </div>
                    <div class="advantage-item">
                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Dipanen segar langsung dari kebun</span>
                    </div>
                    <div class="advantage-item">
                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Mendukung petani lokal Desa Manud Jaya</span>
                    </div>
                    <div class="advantage-item">
                        <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        <span>Harga transparan langsung dari petani</span>
                    </div>
                </div>
            </div>

            <!-- Product Info Cards -->
            <div class="info-cards">
                <div class="info-card farmer-card">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M20 10c0-3.866-3.582-7-8-7s-8 3.134-8 7c0 2.742 1.436 5.136 3.564 6.414.068.091.15.176.248.267.876.648 1.834 1.2 2.874 1.576.584.25 1.19.382 1.814.382.844 0 1.65-.21 2.406-.607 1.04-.376 1.998-.928 2.874-1.576.098-.091.18-.176.248-.267 2.128-1.278 3.564-3.672 3.564-6.414z"/>
                        </svg>
                        <span class="info-label-text">Petani</span>
                    </div>
                    <p class="info-value">Pak Budi - Desa Manud Jaya</p>
                </div>

                <div class="info-card stock-card">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        <span class="info-label-text">Stok Tersedia</span>
                    </div>
                    <p class="info-value"><%= product.stock || '50' %> per ikat (250g)</p>
                </div>

                <div class="info-card harvest-card">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <circle cx="12" cy="12" r="1"/>
                            <path d="M12 1v6m0 6v6"/>
                            <path d="M4.22 4.22l4.24 4.24m2.12 2.12l4.24 4.24"/>
                            <path d="M1 12h6m6 0h6"/>
                            <path d="M4.22 19.78l4.24-4.24m2.12-2.12l4.24-4.24"/>
                        </svg>
                        <span class="info-label-text">Panen Terakhir</span>
                    </div>
                    <p class="info-value">2 hari yang lalu</p>
                </div>
            </div>

            <!-- Price Section -->
            <div class="price-section">
                <span class="price-text">Rp <%= (product.price || 10000).toLocaleString('id-ID') %></span>
                <span class="price-unit">per 1/4 kg (250g)</span>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <button class="btn-add-cart" onclick="addToCart(<%= product.id %>)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                </button>
                <button class="btn-order" onclick="orderNow(<%= product.id %>)">Pesan Sekarang</button>
            </div>
        </div>
    </div>
</div>

<script src="/js/product-detail.js"></script>
