<% layout = 'layout' %>

<div class="product-detail-page">
    <!-- Header -->
    <header class="page-header">
        <div class="header-logo">
            <img src="/logo.png" alt="LumiTani" class="logo-image">
        </div>
    </header>

    <!-- Main Content -->
    <div class="detail-container">
        <!-- Left: Product Images -->
        <div class="product-images-section">
            <div class="product-image-main">
                <img id="mainImage" src="<%= product.photo_url || 'https://via.placeholder.com/500' %>" alt="<%= product.name %>">
            </div>
            <div class="product-thumbnails">
                <% for (let i = 0; i < 4; i++) { %>
                    <div class="thumbnail <%= i === 0 ? 'active' : '' %>" onclick="changeImage(this)">
                        <img src="<%= product.photo_url || 'https://via.placeholder.com/100' %>" alt="Thumbnail <%= i + 1 %>">
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Right: Product Details -->
        <div class="product-info-section">
            <!-- Title with Badge -->
            <div class="product-header">
                <h1 class="product-title">
                    <%= product.name || 'Produk Organik' %>
                    <span class="premium-badge">Premium</span>
                </h1>
            </div>

            <!-- Description -->
            <p class="product-description">
                <%= product.description || 'Produk organik berkualitas dari petani lokal dengan harga terjangkau dan transparansi penuh.' %>
            </p>

            <!-- Product Advantages -->
            <% if (product.keunggulan_produk && product.keunggulan_produk.length > 0) { %>
                <div class="advantages-section">
                    <h3 class="section-title">Keunggulan Produk</h3>
                    <div class="advantages-list">
                        <% product.keunggulan_produk.forEach(function(advantage) { %>
                            <div class="advantage-item">
                                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                <span><%= advantage %></span>
                            </div>
                        <% }); %>
                    </div>
                </div>
            <% } else { %>
                <div class="advantages-section">
                    <h3 class="section-title">Keunggulan Produk</h3>
                    <div class="advantages-list">
                        <div class="advantage-item">
                            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Produk berkualitas dari petani lokal</span>
                        </div>
                        <div class="advantage-item">
                            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Dipanen segar langsung dari kebun</span>
                        </div>
                        <div class="advantage-item">
                            <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span>Harga transparan langsung dari petani</span>
                        </div>
                    </div>
                </div>
            <% } %>

                    <div class="product-info-cards">
                        <div class="info-card">
                            <span class="info-label">PETANI</span>
                            <span class="info-value"><%= product.farmer_name || 'Petani Lokal' %></span>
                        </div>
                        <div class="info-card">
                            <span class="info-label">STOK TERSEDIA</span>
                            <span class="info-value"><%= product.stock || 0 %> unit</span>
                        </div>
                        <% if (product.panen_terakhir) { %>
                        <div class="info-card">
                            <span class="info-label">PANEN TERAKHIR</span>
                            <span class="info-value"><%= Math.floor((Date.now() - new Date(product.panen_terakhir).getTime()) / (1000 * 60 * 60 * 24)) %> hari yang lalu</span>
                        </div>
                        <% } %>
                    </div>

            <!-- Price Section -->
            <div class="price-section">
                <span class="price-text">Rp <%= (product.current_price || product.price || 10000).toLocaleString('id-ID') %></span>
                <span class="price-unit">per 1/4 kg (250g)</span>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <button class="btn-add-cart" onclick="addToCart(<%= product.id %>)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"/>
                        <circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                </button>
                <button class="btn-order" onclick="orderNow(<%= product.id %>)">Pesan Sekarang</button>
            </div>
        </div>
    </div>
</div>

<script src="/js/product-detail.js"></script>
