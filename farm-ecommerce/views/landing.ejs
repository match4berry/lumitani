<% layout = 'layout' %>

<!-- Hero Section with Green Banner -->
<section class="hero-banner">
    <div class="hero-badge">Segar!</div>
    <div class="hero-content">
        <h1 class="hero-title">Langsung dari Petani Lokal</h1>
        <p class="hero-subtitle">100% Organik • Harga Transparan • Segar Setiap Hari</p>
        <a href="/catalog" class="hero-button">Belanja Sekarang ></a>
    </div>
    <div class="hero-decorations">
        <span class="decoration top-right">◯</span>
        <span class="decoration bottom-left">◯</span>
    </div>
</section>

<!-- Best Seller Section -->
<% if (products && products.length > 0) { %>
<section class="best-seller-section">
    <div class="section-header">
        <h2 class="section-title">⭐ Best Seller</h2>
        <a href="/catalog" class="link-text">Lihat Semua ></a>
    </div>
    <div class="products-scroll">
        <% products.slice(0, 6).forEach(product => { %>
            <div class="product-card-home">
                <div class="product-badge">Best</div>
                <div class="product-image">
                    <img 
                        src="<%= product.photo_url || (product.images && product.images[0] ? product.images[0] : 'https://via.placeholder.com/200') %>" 
                        alt="<%= product.name %>"
                        loading="lazy"
                        style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div class="product-name"><%= product.name %></div>
                <div class="product-price">Rp <%= product.current_price ? product.current_price.toLocaleString('id-ID') : (product.price ? product.price.toLocaleString('id-ID') : '0') %>/kg</div>
            </div>
        <% }); %>
    </div>
</section>
<% } %>

<!-- Category Section -->
<section class="category-section">
    <div class="section-header">
        <h2 class="section-title">🌾 Kategori Produk</h2>
        <a href="/catalog" class="link-text">Lihat Semua ></a>
    </div>
    <div class="categories-grid-home">
        <a href="/?category=sayuran" class="category-card-home" style="background: #D1F4E0;">
            <span class="category-emoji">🥬</span>
            <span class="category-label">Sayuran Hijau</span>
        </a>
        <a href="/?category=buah" class="category-card-home" style="background: #FFD6E8;">
            <span class="category-emoji">🍅</span>
            <span class="category-label">Buah-buahan</span>
        </a>
        <a href="/?category=umbi" class="category-card-home" style="background: #FFF4D6;">
            <span class="category-emoji">🥕</span>
            <span class="category-label">Umbi-umbian</span>
        </a>
        <a href="/?category=bumbu" class="category-card-home" style="background: #D1F4E0;">
            <span class="category-emoji">🌿</span>
            <span class="category-label">Bumbu Dapur</span>
        </a>
    </div>
</section>
