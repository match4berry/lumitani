<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'LumiTani - Marketplace Petani Organik' %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/home.css">
    <link rel="stylesheet" href="/css/catalog.css">
    <link rel="stylesheet" href="/css/about.css">
</head>
<body>
    <!-- Main App Container -->
    <div class="app-container">
        <!-- Header -->
        <header class="page-header">
            <div class="header-content">
                <div class="logo">
                    <span class="logo-icon">🌱</span>
                    <span class="logo-text">LumiTani</span>
                </div>
                <button class="menu-button" onclick="toggleSidebar()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
            </div>
        </header>

        <!-- Sidebar -->
        <div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleSidebar()">
            <nav id="sidebar" class="sidebar" onclick="event.stopPropagation()">
                <div class="sidebar-header">
                    <h2 class="sidebar-title">LumiTani</h2>
                    <button id="close-sidebar" class="close-sidebar" onclick="toggleSidebar()">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>
                <div class="sidebar-content">
                    <a href="/" class="sidebar-link">🏠 Beranda</a>
                    <a href="/catalog" class="sidebar-link">📦 Semua Produk</a>
                    <a href="/cart" class="sidebar-link">🛒 Keranjang</a>
                    <a href="/about" class="sidebar-link">ℹ️ Tentang Kami</a>
                    <a href="/profile" class="sidebar-link">👤 Profil</a>
                </div>
            </nav>
        </div>

        <!-- Page Content -->
        <main class="page-content">
            <%- body %>
        </main>

        <!-- Bottom Navigation -->
        <nav class="bottom-nav">
            <a href="/" class="nav-item" data-page="home">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span class="nav-label">Home</span>
            </a>
            <a href="/catalog" class="nav-item" data-page="catalog">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                </svg>
                <span class="nav-label">Katalog</span>
            </a>
            <a href="/cart" class="nav-item nav-cart-center" data-page="cart">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="9" cy="21" r="1"/>
                    <circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
                <span class="nav-label">Keranjang</span>
                <span id="cart-badge" class="cart-badge" style="display: none;">0</span>
            </a>
            <a href="/about" class="nav-item" data-page="about">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="16" x2="12" y2="12"/>
                    <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
                <span class="nav-label">Tentang</span>
            </a>
            <a href="/profile" class="nav-item" data-page="profile">
                <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="nav-label">Profil</span>
            </a>
        </nav>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast"></div>

    <script>
        function toggleSidebar() {
            const overlay = document.getElementById('sidebar-overlay');
            overlay.classList.toggle('active');
        }
    </script>
    <script src="/js/script.js"></script>
</body>
</html>
