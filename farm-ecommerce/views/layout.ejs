<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'LumiTani - Farm E-commerce' %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Toast Notification -->
    <div id="toast" class="toast hidden">
        <svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <span id="toast-message"></span>
    </div>

    <!-- Sidebar -->
    <div id="sidebar" class="sidebar">
        <div class="sidebar-content">
            <button class="close-button" onclick="toggleSidebar()">✕</button>
            <nav class="sidebar-nav">
                <a href="/" class="nav-link">Home</a>
                <a href="/catalog" class="nav-link">Katalog</a>
                <a href="/cart" class="nav-link">Keranjang</a>
                <a href="/profile" class="nav-link">Profil</a>
                <a href="/about" class="nav-link">Tentang</a>
            </nav>
        </div>
    </div>

    <!-- Main Content -->
    <div class="app-container">
        <!-- Header -->
        <header class="landing-header">
            <div class="header-content">
                <div class="logo">
                    <span class="logo-icon">🌱</span>
                    <span class="logo-text">LumiTani</span>
                </div>
                <button class="menu-button" onclick="toggleSidebar()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
            </div>
        </header>

        <!-- Page Content -->
        <div class="page-content">
            <%- body %>
        </div>

        <!-- Bottom Navigation -->
        <nav class="bottom-nav">
            <a href="/" class="nav-item">
                <span class="nav-icon">🏠</span>
                <span class="nav-label">Home</span>
            </a>
            <a href="/catalog" class="nav-item">
                <span class="nav-icon">📦</span>
                <span class="nav-label">Katalog</span>
            </a>
            <a href="/cart" class="nav-item">
                <span class="nav-icon">🛒</span>
                <span class="nav-label">Keranjang</span>
            </a>
            <a href="/profile" class="nav-item">
                <span class="nav-icon">👤</span>
                <span class="nav-label">Profil</span>
            </a>
        </nav>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>
