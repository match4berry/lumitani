<!DOCTYPE html>
<html>

<head>
    <title>Checkout - Lumitani</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/style.css">
    <style>
        .loading { text-align: center; padding: 2rem; color: #999; }
        .error-message { color: #dc2626; padding: 1rem; background: #fee2e2; border-radius: 4px; margin: 1rem 0; }
        .product { display: flex; gap: 1rem; margin: 1rem 0; padding: 1rem; border-bottom: 1px solid #eee; }
    </style>
</head>

<body>

<div class="container">

    <header class="page-header">
        <div class="header-logo">
            <img src="/logo.png" alt="LumiTani" class="logo-image">
        </div>
    </header>

    <h2>Checkout</h2>
    <p>Ringkasan pesanan kamu</p>

    <div class="checkout-grid">

        <!-- KIRI -->
        <div>
            <div class="card">
                <h3>Ringkasan Pesanan</h3>
                <div id="orderSummary">
                    <div class="loading">
                        <p>Memuat data cart...</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- KANAN -->
        <div>
            <form id="checkoutForm" action="/order" method="POST">

                <div class="card">
                    <h3>Alamat Pengiriman</h3>

                    <div class="form-group">
                        <label>Nama Penerima</label>
                        <input type="text" name="name" placeholder="Masukkan nama penerima" required>
                    </div>

                    <div class="form-group">
                        <label>Nomor Telepon</label>
                        <input type="text" name="phone" placeholder="Masukkan nomor telepon">
                    </div>

                    <div class="form-group">
                        <label>Alamat Lengkap</label>
                        <textarea name="address" placeholder="Masukkan alamat lengkap" required></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Kota</label>
                            <input type="text" name="city" placeholder="Masukkan kota">
                        </div>
                        <div class="form-group">
                            <label>Kode Pos</label>
                            <input type="text" name="postal" placeholder="Masukkan kode pos">
                        </div>
                    </div>
                </div>

                <div class="card payment">
                    <h3>Metode Pembayaran</h3>

                    <label><input type="radio" name="payment" value="bank" required> Transfer Bank</label>
                    <label><input type="radio" name="payment" value="ewallet"> E-Wallet</label>
                    <label><input type="radio" name="payment" value="cod"> COD</label>
                </div>

                <!-- Hidden fields to pass items and total (populated by JavaScript) -->
                <input type="hidden" id="itemsField" name="items" value="[]">
                <input type="hidden" id="totalField" name="total" value="0">

                <button type="submit" id="orderBtn">Order Now</button>

            </form>
        </div>

    </div>

</div>

<script>
    // Fetch cart from API and populate checkout
    async function loadCheckoutData() {
        try {
            console.log('[CHECKOUT] Loading cart data from API...');
            
            const response = await fetch('/api/cart', {
                method: 'GET',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'include'
            });
            
            if (response.status === 401) {
                document.getElementById('orderSummary').innerHTML = `
                    <div class="error-message">
                        Silakan <a href="/login">login terlebih dahulu</a>
                    </div>
                `;
                return;
            }
            
            if (!response.ok) {
                throw new Error(`Failed to fetch cart (${response.status})`);
            }
            
            const data = await response.json();
            
            if (!data.items || data.items.length === 0) {
                document.getElementById('orderSummary').innerHTML = `
                    <div class="error-message">
                        Keranjang Anda kosong. <a href="/catalog">Mulai belanja di sini</a>
                    </div>
                `;
                document.getElementById('orderBtn').disabled = true;
                return;
            }
            
            renderCheckoutItems(data.items);
            updateHiddenFields(data.items);
            
        } catch (error) {
            console.error('[CHECKOUT] Error loading cart:', error);
            document.getElementById('orderSummary').innerHTML = `
                <div class="error-message">
                    Terjadi kesalahan saat memuat keranjang. Silakan coba kembali.
                </div>
            `;
            document.getElementById('orderBtn').disabled = true;
        }
    }
    
    // Render cart items to checkout summary
    function renderCheckoutItems(items) {
        let html = '';
        let total = 0;
        
        items.forEach(item => {
            const itemTotal = (item.price || 0) * (item.quantity || 1);
            total += itemTotal;
            
            // Use actual product image
            const imageUrl = item.photo_url || item.image || 'https://via.placeholder.com/100';
            
            html += `
                <div class="product">
                    <div class="product-icon">
                        <img src="${imageUrl}" alt="${item.name || 'Produk'}" style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;">
                    </div>
                    <div class="product-info">
                        <p>${item.name || 'Produk'}</p>
                        <small>Rp ${(item.price || 0).toLocaleString('id-ID')} x ${item.quantity || 1}</small>
                        <div class="price">Rp ${itemTotal.toLocaleString('id-ID')}</div>
                    </div>
                </div>
            `;
        });
        
        html += `<hr><p><b>Total: Rp ${total.toLocaleString('id-ID')}</b></p>`;
        
        document.getElementById('orderSummary').innerHTML = html;
    }
    
    // Update hidden form fields with cart data
    function updateHiddenFields(items) {
        const itemsField = document.getElementById('itemsField');
        const totalField = document.getElementById('totalField');
        
        let total = 0;
        const itemsForOrder = items.map(item => {
            const itemTotal = (item.price || 0) * (item.quantity || 1);
            total += itemTotal;
            return {
                name: item.name,
                price: item.price,
                quantity: item.quantity
            };
        });
        
        itemsField.value = JSON.stringify(itemsForOrder);
        totalField.value = total;
        
        console.log('[CHECKOUT] Updated hidden fields with', itemsForOrder.length, 'items, total:', total);
    }
    
    // Load checkout data when page loads
    document.addEventListener('DOMContentLoaded', function() {
        loadCheckoutData();
    });
</script>

</body>
</html>


