<% layout = 'layout' %>

<div class="cart-page">
    <!-- Header -->
    <header class="page-header">
        <div class="header-logo">
            <img src="/logo.png" alt="LumiTani" class="logo-image">
        </div>
    </header>

    <div class="cart-container">
        <!-- Left Sidebar: Filter -->
        <aside class="cart-sidebar">
            <div class="filter-section">
                <h3 class="filter-title">Urutkan</h3>
                <div class="filter-options">
                    <button class="filter-btn active" onclick="filterCart('all')">Semua</button>
                    <button class="filter-btn" onclick="filterCart('sayuran')">Sayur</button>
                    <button class="filter-btn" onclick="filterCart('buah-buahan')">Buah</button>
                    <button class="filter-btn" onclick="filterCart('umbi-umbian')">Umbi</button>
                    <button class="filter-btn" onclick="filterCart('bumbu-dapur')">Bumbu Dapur</button>
                </div>
            </div>
        </aside>

        <!-- Right: Cart Content -->
        <div class="cart-main">
            <!-- Cart Items -->
            <div class="cart-items">
                <!-- Item 1 -->
                <div class="cart-item">
                    <div class="item-checkbox">
                        <input type="checkbox" class="item-check" checked>
                    </div>
                    <div class="item-image">
                        <img src="/images/rawit.jpg" alt="Rawit Merah Super">
                    </div>
                    <div class="item-info">
                        <h4 class="item-name">Rawit Merah Super</h4>
                        <p class="item-price">Rp 10.000 / 250g</p>
                    </div>
                    <div class="item-quantity">
                        <button class="qty-btn minus" onclick="decreaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                        <input type="number" class="qty-input" value="1" min="1">
                        <button class="qty-btn plus" onclick="increaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                    </div>
                    <div class="item-total">
                        <div class="total-label">Total</div>
                        <div class="total-price">Rp 10.000</div>
                    </div>
                    <button class="item-delete" onclick="deleteItem(this)">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-9l-1 1H5v2h14V4z"/>
                        </svg>
                    </button>
                </div>

                <!-- Item 2 -->
                <div class="cart-item">
                    <div class="item-checkbox">
                        <input type="checkbox" class="item-check" checked>
                    </div>
                    <div class="item-image">
                        <img src="/images/tomat.jpg" alt="Tomat Merah Manud Jaya">
                    </div>
                    <div class="item-info">
                        <h4 class="item-name">Tomat Merah Manud Jaya - Kualitas I...</h4>
                        <p class="item-price">Rp 15.000 / 250g</p>
                    </div>
                    <div class="item-quantity">
                        <button class="qty-btn minus" onclick="decreaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                        <input type="number" class="qty-input" value="2" min="1">
                        <button class="qty-btn plus" onclick="increaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                    </div>
                    <div class="item-total">
                        <div class="total-label">Total</div>
                        <div class="total-price">Rp 30.000</div>
                    </div>
                    <button class="item-delete" onclick="deleteItem(this)">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-9l-1 1H5v2h14V4z"/>
                        </svg>
                    </button>
                </div>

                <!-- Item 3 -->
                <div class="cart-item">
                    <div class="item-checkbox">
                        <input type="checkbox" class="item-check" checked>
                    </div>
                    <div class="item-image">
                        <img src="/images/mentimun.jpg" alt="Mentimun Lokal">
                    </div>
                    <div class="item-info">
                        <h4 class="item-name">Mentimun Lokal Manud Jaya</h4>
                        <p class="item-price">Rp 3.000 / 250g</p>
                    </div>
                    <div class="item-quantity">
                        <button class="qty-btn minus" onclick="decreaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                        <input type="number" class="qty-input" value="1" min="1">
                        <button class="qty-btn plus" onclick="increaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                    </div>
                    <div class="item-total">
                        <div class="total-label">Total</div>
                        <div class="total-price">Rp 3.000</div>
                    </div>
                    <button class="item-delete" onclick="deleteItem(this)">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-9l-1 1H5v2h14V4z"/>
                        </svg>
                    </button>
                </div>

                <!-- Item 4 -->
                <div class="cart-item">
                    <div class="item-checkbox">
                        <input type="checkbox" class="item-check" checked>
                    </div>
                    <div class="item-image">
                        <img src="/images/wortel.jpg" alt="Wortel Manud Jaya">
                    </div>
                    <div class="item-info">
                        <h4 class="item-name">Wortel Manud Jaya - Kualitas Import</h4>
                        <p class="item-price">Rp 8.000 / 250g</p>
                    </div>
                    <div class="item-quantity">
                        <button class="qty-btn minus" onclick="decreaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                        <input type="number" class="qty-input" value="4" min="1">
                        <button class="qty-btn plus" onclick="increaseQty(this)">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                            </svg>
                        </button>
                    </div>
                    <div class="item-total">
                        <div class="total-label">Total</div>
                        <div class="total-price">Rp 32.000</div>
                    </div>
                    <button class="item-delete" onclick="deleteItem(this)">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-9l-1 1H5v2h14V4z"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Cart Summary -->
            <div class="cart-summary">
                <div class="summary-total">
                    <span class="total-amount">Rp 75.000</span>
                    <span class="total-items">sub total 4 item</span>
                </div>
                <button class="btn-order-now" onclick="proceedToCheckout()">Pesan Sekarang</button>
            </div>
        </div>
    </div>
</div>

<script src="/js/cart.js"></script>
