<% layout = 'layout' %>

<header class="page-header">
    <a href="/" class="back-button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
    </a>
    <h1>Tentang Kami</h1>
</header>

<div class="page-content">
    <div class="about-container">
        <section class="about-section">
            <h2>Selamat Datang di LumiTani</h2>
            <p>
                Kami adalah platform e-commerce yang didedikasikan untuk menyediakan produk pertanian segar langsung dari petani lokal ke meja makan Anda.
            </p>
        </section>

        <section class="about-section">
            <h2>Misi Kami</h2>
            <p>
                Memberdayakan petani lokal dan menyediakan konsumen dengan produk-produk berkualitas tinggi, segar, dan terjangkau.
            </p>
        </section>

        <section class="about-section">
            <h2>Visi Kami</h2>
            <p>
                Menjadi platform pertanian terpercaya yang menghubungkan petani dengan konsumen secara langsung dan berkelanjutan.
            </p>
        </section>

        <section class="about-section">
            <h2>Mengapa Memilih Kami?</h2>
            <ul>
                <li>✓ Produk segar langsung dari petani</li>
                <li>✓ Harga kompetitif dan terjangkau</li>
                <li>✓ Kualitas terjamin</li>
                <li>✓ Pengiriman cepat dan aman</li>
                <li>✓ Layanan pelanggan yang responsif</li>
            </ul>
        </section>

        <section class="about-section">
            <h2>Kategori Produk</h2>
            <p>Kami menyediakan berbagai kategori produk pertanian:</p>
            <div class="categories-list">
                <div class="category-item">🥬 Sayuran Segar</div>
                <div class="category-item">🌾 Padi-padian</div>
                <div class="category-item">🥔 Umbi-umbian</div>
                <div class="category-item">🍌 Buah-buahan</div>
                <div class="category-item">🌶️ Bumbu-dapur</div>
            </div>
        </section>
    </div>
</div>
