<% layout = 'layout' %>

<link rel="stylesheet" href="/css/about.css">

<header class="page-header">
    <div class="header-logo">
        <img src="/logo.png" alt="LumiTani" class="logo-image">
    </div>
</header>

<!-- Hero Section -->
<section class="about-hero">
    <div class="hero-logo">
        <div class="logo-badge">
            <img src="/logo.png" alt="LumiTani" class="logo-badge-image">
        </div>
    </div>
    <h2 class="hero-title">Tentang LumiTani</h2>
    <p class="hero-subtitle">Platform Marketplace Pertanian Organik</p>
</section>

<!-- Description Card -->
<div class="about-content">
    <div class="description-card">
        <div class="description-icon">🌿</div>
        <p class="description-text">
            LumiTani adalah platform web yang dirancang untuk 
            <span class="highlight">meningkatkan kesejahteraan petani Desa Manud Jaya</span> 
            dengan memperluas akses pasar ke konsumen dan pelaku usaha perkotaan melalui 
            sistem transaksi yang <span class="highlight">terkelola, transparan dan berbasis teknologi</span>.
        </p>
    </div>

    <!-- Farm Images -->
    <div class="farm-images">
        <img src="https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=400&h=250&fit=crop" alt="Berkebun Organik" class="farm-image">
        <img src="https://images.unsplash.com/photo-1625246333195-78d9c38ad576?w=400&h=250&fit=crop" alt="Pertanian Organik" class="farm-image">
    </div>

    <!-- Advantages Section -->
    <section class="advantages-section">
        <h3 class="section-title">✨ Keunggulan LumiTani</h3>
        
        <div class="advantages-grid">
            <div class="advantage-card">
                <div class="advantage-icon organic">🌿</div>
                <h4 class="advantage-title">100% Organik</h4>
                <p class="advantage-desc">Produk langsung dari petani lokal Desa Manud Jaya tanpa pestisida kimia</p>
            </div>

            <div class="advantage-card">
                <div class="advantage-icon transparent">✓</div>
                <h4 class="advantage-title">Transparan & Terkelola</h4>
                <p class="advantage-desc">Sistem transaksi berbasis teknologi yang aman dan terpercaya</p>
            </div>

            <div class="advantage-card">
                <div class="advantage-icon price">📈</div>
                <h4 class="advantage-title">Harga Adil</h4>
                <p class="advantage-desc">Tanpa perantara berlebih, petani dapat harga layak, konsumen hemat</p>
            </div>

            <div class="advantage-card">
                <div class="advantage-icon market">👥</div>
                <h4 class="advantage-title">Akses Pasar Luas</h4>
                <p class="advantage-desc">Menghubungkan petani dengan konsumen dan pelaku usaha perkotaan</p>
            </div>
        </div>
    </section>

    <!-- Mission Section -->
    <section class="mission-section">
        <div class="mission-icon">🌱</div>
        <h3 class="mission-title">Misi Kami</h3>
        <p class="mission-text">
            Membangun ekosistem pertanian yang berkelanjutan dengan menghubungkan langsung 
            dengan konsumen perkotaan, menciptakan nilai tambah bagi semua pihak.
        </p>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <h3 class="cta-title">Mulai Belanja Sekarang!</h3>
        <p class="cta-text">Dukung petani lokal dengan berbelanja produk organik segar</p>
        <a href="/catalog" class="cta-button">Lihat Katalog Produk</a>
    </section>
</div>
