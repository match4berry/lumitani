<% layout = 'layout' %>

<header class="page-header">
    <a href="/" class="back-button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
    </a>
    <h1>Katalog Produk</h1>
</header>

<!-- Category Filter -->
<div class="filter-section">
    <div class="filter-chips">
        <a href="/catalog" class="chip <%= currentCategory === 'all' ? 'active' : '' %>">Semua</a>
        <% if (categories && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
                <a href="/catalog?category=<%= cat %>" class="chip <%= currentCategory === cat ? 'active' : '' %>">
                    <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
                </a>
            <% }); %>
        <% } %>
    </div>
</div>

<!-- Products Grid -->
<div class="page-content">
    <% if (products && products.length > 0) { %>
        <div class="products-grid">
            <% products.forEach(product => { %>
                <div class="product-card">
                    <div class="product-image">
                        <img src="<%= product.photo_url || (product.images && product.images[0] ? product.images[0] : 'https://via.placeholder.com/200') %>" alt="<%= product.name %>">
                    </div>
                    <div class="product-info">
                        <h3 class="product-name"><%= product.name %></h3>
                        <p class="product-description"><%= product.commodity_name || (product.description ? product.description.substring(0, 60) + '...' : '') %></p>
                        <div class="product-footer">
                            <span class="product-price">Rp <%= product.current_price ? product.current_price.toLocaleString('id-ID') : (product.price ? product.price.toLocaleString('id-ID') : '0') %></span>
                            <a href="/product/<%= product.id %>" class="btn btn-small">Lihat</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <p>Tidak ada produk tersedia</p>
        </div>
    <% } %>
</div>
